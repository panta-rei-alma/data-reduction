# Panta Rei Configuration
# Copy this file to .env and fill in your paths:
#   cp .env.example .env
#
# Do NOT commit .env to git — it contains site-specific paths.

# Base directory for panta_rei data (parent of project directories)
PANTA_REI_BASE=/path/to/panta_rei

# Project code (used to construct project-specific paths)
PROJECT_CODE=2025.1.00383.L

# CASA installation path (optional — only needed for calibration workflow)
CASA_PATH=/path/to/casa-6.6.6-17-pipeline-2025.1.0.35-py3.10.el8

# Weblog staging directory (typically on a web-accessible NAS)
WEBLOG_DIR=/path/to/weblogs

# Log directory for cron/systemd jobs
CRON_LOG_DIR=/path/to/cron_logs

# Python environment for systemd service
PYTHON_ENV=/path/to/conda/envs/pantarei

# ALMA archive username
ALMA_USER=your_username
